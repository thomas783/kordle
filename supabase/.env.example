# 로컬 Supabase(CLI)에서 카카오 OAuth를 쓸 때만 필요.
# 복사: cp supabase/.env.example supabase/.env  (supabase/.env 는 gitignore됨)
# 값: 카카오 개발자 > 앱 > 플랫폼 키 의 REST API 키 / 클라이언트 시크릿
#
# ⚠️ 로컬 콜백 http://127.0.0.1:54321/auth/v1/callback 을
#    카카오 Redirect URI에 추가 등록해야 로컬 로그인이 됩니다.
SUPABASE_AUTH_EXTERNAL_KAKAO_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_KAKAO_SECRET=
